{
  "__inputs": [],
  "__requires": [],
  "title": "DRL-1  GOTHAM",
  "uid": "drl-gotham-001",
  "schemaVersion": 38,
  "refresh": "5s",
  "time": { "from": "now-5m", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "tags": ["gotham", "ratelimiter", "production"],
  "templating": {
    "list": [
      {
        "name": "clientId",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(rl_requests_allowed_total, clientId)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "sort": 1,
        "label": "Client"
      }
    ]
  },
  "style": "dark",
  "panels": [
    {
      "id": 1,
      "title": "RPS",
      "type": "stat",
      "description": "Total throughput (allowed + rejected)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "rate(rl_requests_allowed_total[30s]) + rate(rl_requests_rejected_total[30s])",
          "legendFormat": "THROUGHPUT"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#00e676", "value": null },
              { "color": "#ff9900", "value": 100 },
              { "color": "#ff6600", "value": 500 },
              { "color": "#ff1744", "value": 1000 }
            ]
          },
          "mappings": []
        }
      }
    },
    {
      "id": 2,
      "title": "REJECTION RATE",
      "type": "stat",
      "description": "% of requests being rate limited",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "rate(rl_requests_rejected_total[1m]) / (rate(rl_requests_allowed_total[1m]) + rate(rl_requests_rejected_total[1m])) * 100",
          "legendFormat": "REJECTION %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#00e676", "value": null },
              { "color": "#ff9900", "value": 5 },
              { "color": "#ff6600", "value": 20 },
              { "color": "#ff1744", "value": 50 }
            ]
          },
          "mappings": []
        }
      }
    },
    {
      "id": 9,
      "title": "ALLOW RATE",
      "type": "stat",
      "description": "% of requests allowed through (1 - rejection rate)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "rate(rl_requests_allowed_total[30s]) / (rate(rl_requests_allowed_total[30s]) + rate(rl_requests_rejected_total[30s])) * 100",
          "legendFormat": "ALLOW %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#ff1744", "value": null },
              { "color": "#ff6600", "value": 50 },
              { "color": "#ff9900", "value": 80 },
              { "color": "#00e676", "value": 95 }
            ]
          },
          "mappings": []
        }
      }
    },
    {
      "id": 8,
      "title": "CIRCUIT BREAKER",
      "type": "stat",
      "description": "OPEN if fallbacks detected, CLOSED otherwise",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "rate(rl_circuitbreaker_fallback_total[1m])",
          "legendFormat": "FALLBACKS"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#00e676", "value": null },
              { "color": "#ff1744", "value": 0.01 }
            ]
          },
          "mappings": [
            { "type": 1, "value": "0", "text": "CLOSED" },
            { "type": 1, "value": "1", "text": "OPEN" }
          ]
        }
      }
    },
    {
      "id": 3,
      "title": "REQUESTS  ALLOWED / REJECTED",
      "type": "timeseries",
      "description": "Green = allowed through, Red = rate limited",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(rl_requests_allowed_total[30s])",
          "legendFormat": "ALLOWED"
        },
        {
          "expr": "rate(rl_requests_rejected_total[30s])",
          "legendFormat": "REJECTED"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 0,
            "showPoints": "never",
            "gradientMode": "opacity"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "ALLOWED" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#00e676", "mode": "fixed" } },
              { "id": "custom.fillOpacity", "value": 15 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "REJECTED" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#ff1744", "mode": "fixed" } },
              { "id": "custom.fillOpacity", "value": 20 }
            ]
          }
        ]
      }
    },
    {
      "id": 4,
      "title": "REDIS LATENCY  p50 / p95 / p99",
      "type": "timeseries",
      "description": "Lua script round-trip latency via virtual threads",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(rl_redis_latency_seconds_bucket[30s])) by (le)) * 1000",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(rl_redis_latency_seconds_bucket[30s])) by (le)) * 1000",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(rl_redis_latency_seconds_bucket[30s])) by (le)) * 1000",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "pointSize": 0,
            "showPoints": "never",
            "gradientMode": "opacity"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p50" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#e68a00", "mode": "fixed" } },
              { "id": "custom.lineWidth", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "p95" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#ff9900", "mode": "fixed" } },
              { "id": "custom.lineWidth", "value": 2 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "p99" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#ff1744", "mode": "fixed" } },
              { "id": "custom.lineWidth", "value": 2 }
            ]
          }
        ]
      }
    },
    {
      "id": 6,
      "title": "REDIS SYNC FAILURES",
      "type": "timeseries",
      "description": "EARLY WARNING — blank = healthy. Spikes mean Redis is unreachable. Precedes CB opening.",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(rl_redis_sync_failure_total[30s])",
          "legendFormat": "FAILURES"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "pointSize": 0,
            "showPoints": "never",
            "gradientMode": "opacity"
          },
          "color": { "fixedColor": "#ff1744", "mode": "fixed" }
        }
      }
    },
    {
      "id": 7,
      "title": "ACTIVE BUCKETS",
      "type": "stat",
      "description": "Client token buckets in local memory (fallback only)",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rl_local_bucket_count", "legendFormat": "BUCKETS" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 1000,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#00e676", "value": null },
              { "color": "#ff9900", "value": 100 },
              { "color": "#ff6600", "value": 500 },
              { "color": "#ff1744", "value": 800 }
            ]
          },
          "mappings": []
        }
      }
    },
    {
      "id": 10,
      "title": "TOP REJECTED CLIENTS",
      "type": "bargauge",
      "description": "Highest rejection rates per client (last 1m)",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "topk(10, sum by(clientId)(rate(rl_requests_rejected_total[1m])))",
          "legendFormat": "{{clientId}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "color": { "mode": "continuous-gry" }
        }
      }
    },
    {
      "id": 11,
      "title": "CIRCUIT BREAKER FALLBACKS",
      "type": "timeseries",
      "description": "EARLY WARNING — blank = healthy. Spikes mean Redis has been down long enough for CB to open.",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(rl_circuitbreaker_fallback_total[30s])",
          "legendFormat": "FALLBACKS"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "pointSize": 0,
            "showPoints": "never",
            "gradientMode": "opacity"
          },
          "color": { "fixedColor": "#ff1744", "mode": "fixed" }
        }
      }
    },
    {
      "id": 12,
      "title": "REQUEST LATENCY  p50 / p95 / p99",
      "type": "timeseries",
      "description": "HTTP endpoint serving time — includes allowed + rate-limited",
      "gridPos": { "x": 0, "y": 30, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{uri=\"/api/v1/products\"}[30s])) by (le)) * 1000",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{uri=\"/api/v1/products\"}[30s])) by (le)) * 1000",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{uri=\"/api/v1/products\"}[30s])) by (le)) * 1000",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "pointSize": 0,
            "showPoints": "never",
            "gradientMode": "opacity"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p50" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#e68a00", "mode": "fixed" } },
              { "id": "custom.lineWidth", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "p95" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#ff9900", "mode": "fixed" } },
              { "id": "custom.lineWidth", "value": 2 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "p99" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#ff1744", "mode": "fixed" } },
              { "id": "custom.lineWidth", "value": 2 }
            ]
          }
        ]
      }
    },
    {
      "id": 13,
      "title": "JVM HEAP  USED",
      "type": "timeseries",
      "description": "G1 heap memory (Eden + Survivor + Old)",
      "gridPos": { "x": 12, "y": 30, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "HEAP"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "pointSize": 0,
            "showPoints": "never",
            "gradientMode": "opacity"
          },
          "color": { "fixedColor": "#00bcd4", "mode": "fixed" },
          "thresholds": {
            "steps": [
              { "color": "#00e676", "value": null },
              { "color": "#ff9900", "value": 200000000 },
              { "color": "#ff1744", "value": 400000000 }
            ]
          }
        }
      }
    },
    {
      "id": 14,
      "title": "GC PAUSE DURATION",
      "type": "timeseries",
      "description": "G1 Young GC pause time",
      "gridPos": { "x": 18, "y": 30, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "jvm_gc_pause_seconds_max{action=\"end of minor GC\"}",
          "legendFormat": "GC PAUSE"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "pointSize": 0,
            "showPoints": "always",
            "gradientMode": "opacity"
          },
          "color": { "fixedColor": "#ff6600", "mode": "fixed" },
          "thresholds": {
            "steps": [
              { "color": "#00e676", "value": null },
              { "color": "#ff9900", "value": 0.01 },
              { "color": "#ff1744", "value": 0.05 }
            ]
          }
        }
      }
    },
    {
      "id": 15,
      "title": "REDIS MEMORY",
      "type": "stat",
      "description": "Redis server heap memory usage",
      "gridPos": { "x": 0, "y": 38, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "redis_memory_used_bytes",
          "legendFormat": "MEMORY"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#00e676", "value": null },
              { "color": "#ff9900", "value": 52428800 },
              { "color": "#ff1744", "value": 104857600 }
            ]
          },
          "mappings": []
        }
      }
    },
    {
      "id": 16,
      "title": "REDIS CLIENTS",
      "type": "stat",
      "description": "Connected Redis clients",
      "gridPos": { "x": 6, "y": 38, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "redis_connected_clients",
          "legendFormat": "CLIENTS"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#00e676", "value": null },
              { "color": "#ff9900", "value": 200 },
              { "color": "#ff1744", "value": 500 }
            ]
          },
          "mappings": []
        }
      }
    },
    {
      "id": 17,
      "title": "REDIS KEYS",
      "type": "stat",
      "description": "Rate limiter keys stored in Redis",
      "gridPos": { "x": 12, "y": 38, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "sum(redis_db_keys)",
          "legendFormat": "KEYS"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#00e676", "value": null },
              { "color": "#ff9900", "value": 500 },
              { "color": "#ff1744", "value": 1000 }
            ]
          },
          "mappings": []
        }
      }
    },
    {
      "id": 18,
      "title": "REDIS CMD RATE",
      "type": "stat",
      "description": "Redis commands per second",
      "gridPos": { "x": 18, "y": 38, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "rate(redis_commands_processed_total[30s])",
          "legendFormat": "CMD/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#00e676", "value": null },
              { "color": "#ff9900", "value": 5000 },
              { "color": "#ff1744", "value": 10000 }
            ]
          },
          "mappings": []
        }
      }
    },
    {
      "id": 19,
      "title": "RATE LIMIT DECISIONS",
      "type": "logs",
      "description": "Live rate limit decisions — click any line to see full details",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "gridPos": { "x": 0, "y": 44, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "{container=\"drl-1-ratelimiter-1\"} |= \"rate_limit\"",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        }
      }
    },
    {
      "id": 20,
      "title": "RATE LIMIT EVENT RATE",
      "type": "timeseries",
      "description": "Allowed vs rejected per second (from logs)",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "gridPos": { "x": 12, "y": 44, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by(container)(count_over_time({container=\"drl-1-ratelimiter-1\"} |= \"rate_limit\" |= \"allowed=true\" [30s]))",
          "legendFormat": "ALLOWED"
        },
        {
          "expr": "sum by(container)(count_over_time({container=\"drl-1-ratelimiter-1\"} |= \"rate_limit\" |= \"allowed=false\" [30s]))",
          "legendFormat": "REJECTED"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "pointSize": 0,
            "showPoints": "never",
            "gradientMode": "opacity"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "ALLOWED" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#00e676", "mode": "fixed" } },
              { "id": "custom.fillOpacity", "value": 15 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "REJECTED" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#ff1744", "mode": "fixed" } },
              { "id": "custom.fillOpacity", "value": 20 }
            ]
          }
        ]
      }
    },
    {
      "id": 21,
      "title": "CLIENT  REQUEST HISTORY",
      "type": "timeseries",
      "description": "Select a client from the dropdown. Green = allowed, Red = rejected.",
      "gridPos": { "x": 0, "y": 52, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(rl_requests_allowed_total{clientId=~\"$clientId\"}[30s])",
          "legendFormat": "ALLOWED — {{clientId}}"
        },
        {
          "expr": "rate(rl_requests_rejected_total{clientId=~\"$clientId\"}[30s])",
          "legendFormat": "REJECTED — {{clientId}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 0,
            "showPoints": "never",
            "gradientMode": "opacity"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "/ALLOWED/" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#00e676", "mode": "fixed" } },
              { "id": "custom.fillOpacity", "value": 15 }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/REJECTED/" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#ff1744", "mode": "fixed" } },
              { "id": "custom.fillOpacity", "value": 20 }
            ]
          }
        ]
      }
    },
    {
      "id": 22,
      "title": "CLIENT  LOG STREAM",
      "type": "logs",
      "description": "Live rate limit logs for the selected client",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "gridPos": { "x": 12, "y": 52, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "{container=\"drl-1-ratelimiter-1\"} |= \"rate_limit\" |~ \"clientId=[^ ]*$clientId[^ ]*\"",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        }
      }
    }
  ]
}
